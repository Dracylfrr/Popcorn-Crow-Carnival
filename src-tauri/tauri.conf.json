{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Popcorn Crow Carnival",
  "version": "0.1.0",
  "identifier": "com.popcorncrow.carnival",
  "build": { "beforeDevCommand": "node ./node_modules/vite/bin/vite.js --port 1420", "devUrl": "http://localhost:1420", "beforeBuildCommand": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build", "frontendDist": "../dist" },
  "app": { "windows": [{ "title": "Popcorn Crow Carnival", "width": 1280, "height": 720, "resizable": true }], "security": { "csp": null } },
  "bundle": { "active": true, "targets": "all", "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"] }
}
